      key: 'id',
      label: 'ID'
    },
    {
      key: 'name',
      label: 'Факультет'
    },
    {
      key: 'short_name',
      label: 'Краткое'
    },
    {
      key: 'dean_employee_id',
      label: 'Декан',
      render: (record) => renderRelation(record.dean_employee_id, employeeNameById)
    },
    {
      key: 'deputy_dean_employee_id',
      label: 'Зам. декана',
      render: (record) => renderRelation(record.deputy_dean_employee_id, employeeNameById)
    }
  ]
}
@endfind
