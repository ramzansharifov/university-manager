@insert-after-once src/renderer/src/pages/administration/ui/UsersAdministrationPanel.tsx
@find
  const [statusMessage, setStatusMessage] = useState<string | null>(null)
  const [errorMessage, setErrorMessage] = useState<string | null>(null)
@endfind
@content
  const usernameInputRef = useRef<HTMLInputElement | null>(null)
@endcontent
@end

@replace-first src/renderer/src/pages/administration/ui/UsersAdministrationPanel.tsx
@find
        <DialogContent
          className="max-h-[90vh] max-w-3xl overflow-y-auto"
          onPointerDownOutside={(event) => {
            event.preventDefault()
          }}
@endfind
@with
        <DialogContent
          className="z-[60] max-h-[90vh] max-w-3xl overflow-y-auto"
          onOpenAutoFocus={(event) => {
            event.preventDefault()

            window.setTimeout(() => {
              usernameInputRef.current?.focus()
            }, 0)
          }}
          onPointerDownOutside={(event) => {
            event.preventDefault()
          }}
@endwith
@end

@replace-first src/renderer/src/pages/administration/ui/UsersAdministrationPanel.tsx
@find
              <Input
                value={formUsername}
                autoComplete="off"
                placeholder="Например: ivanov"
                onChange={(event) => setFormUsername(event.target.value)}
              />
@endfind
@with
              <Input
                ref={usernameInputRef}
                value={formUsername}
                autoComplete="username"
                placeholder="Например: ivanov"
                error={Boolean(errorMessage && !formUsername.trim())}
                onChange={(event) => {
                  setFormUsername(event.target.value)

                  if (errorMessage) {
                    setErrorMessage(null)
                  }
                }}
              />
@endwith
@end

