              <Input
                value={formPassword}
                type="password"
                autoComplete="new-password"
                placeholder={
                  dialogMode === 'create'
                    ? 'Минимум 4 символа'
                    : 'Оставь пустым, если пароль менять не нужно'
                }
                error={Boolean(errorMessage && dialogMode === 'create' && formPassword.length < 4)}
                onChange={(event) => {
                  setFormPassword(event.target.value)

                  if (errorMessage) {
                    setErrorMessage(null)
                  }
                }}
              />
@endwith
