@replace-all src/main/database/schemaValidation.ts
@find
    validateSystemColumnConfig(
      config.tableName,
      config.allowedColumns,
      config.hasUpdatedAt,
      config.supportsArchive
    )
@endfind
@with
    validateSystemColumnConfig(
      config.tableName,
      config.allowedColumns,
      config.hasUpdatedAt
    )
@endwith
@end